# Dirección o nombre DNS del servidor SMTP que enviará los correos del formulario.
SMTP_SERVER=smtp.example.com
# Puerto del servidor SMTP: normalmente 587 para STARTTLS o 465 para TLS implícito.
SMTP_PORT=587
# Cuenta autorizada que se usará como remitente y para autenticarse en SMTP.
SMTP_USERNAME=usuario@example.com
# Contraseña o clave de aplicación de la cuenta SMTP. No subas el valor real al repositorio.
SMTP_PASSWORD=cambiar_por_secreto
# Destinatarios generales del formulario, separados por comas.
CONTACT_EMAIL_RECIPIENTS=info@paraisodeljamon.com,galendos@gmail.com
# Destinatarios usados cuando el motivo del formulario es error, separados por comas.
CONTACT_ERROR_EMAIL_RECIPIENTS=galendos@gmail.com
# Tiempo máximo, en segundos, para conectar y completar el envío SMTP.
SMTP_TIMEOUT_SECONDS=15
# Modo de cifrado SMTP. Valores admitidos: starttls | tls | none. El valor habitual en el puerto 587 es starttls.
SMTP_TLS_MODE=starttls

# URL asíncrona completa de SQLAlchemy para MySQL mediante aiomysql.
DATABASE_URL=mysql+aiomysql://usuario:contrasena@127.0.0.1:3306/paraisoweb
# Activa el log completo de sentencias SQL. Valores admitidos: true | false. Mantén false en producción para evitar ruido y exposición de parámetros.
DATABASE_ECHO_SQL=false
# Tiempo máximo, en segundos, que el arranque espera a MySQL antes de continuar degradado.
DATABASE_STARTUP_TIMEOUT_SECONDS=10
# Tiempo máximo, en segundos, para la consulta SELECT 1 realizada por /health.
HEALTHCHECK_DATABASE_TIMEOUT_SECONDS=2

# Clave privada usada para firmar tokens temporales y anonimizar IP en logs de rate limit.
secret_key=cambiar_por_una_clave_aleatoria_de_32_caracteres_o_mas
# Duración, en segundos, de cada intervalo usado para generar los tokens temporales.
token_interval_seconds=60

# Solicitudes totales permitidas por cliente durante la ventana global.
GLOBAL_RATE_LIMIT_REQUESTS=300
# Duración, en segundos, de la ventana del límite global.
GLOBAL_RATE_LIMIT_WINDOW_SECONDS=60
# Consultas permitidas por cliente a /health y /livez durante su ventana.
STATUS_RATE_LIMIT_REQUESTS=120
# Duración, en segundos, de la ventana para los endpoints de estado.
STATUS_RATE_LIMIT_WINDOW_SECONDS=60
# Lecturas permitidas por cliente y endpoint de blog o charcutería.
READ_RATE_LIMIT_REQUESTS=120
# Duración, en segundos, de la ventana para endpoints de lectura.
READ_RATE_LIMIT_WINDOW_SECONDS=60
# Consultas permitidas desde el servidor local al endpoint de datos del sitemap.
SITEMAP_RATE_LIMIT_REQUESTS=12
# Duración, en segundos, de la ventana del endpoint de sitemap.
SITEMAP_RATE_LIMIT_WINDOW_SECONDS=60
# Envíos de contacto permitidos por cliente durante la ventana del formulario.
CONTACT_RATE_LIMIT_REQUESTS=5
# Duración, en segundos, de la ventana del formulario de contacto.
CONTACT_RATE_LIMIT_WINDOW_SECONDS=600
# Solicitudes de token temporal permitidas por cliente durante su ventana.
TOKEN_RATE_LIMIT_REQUESTS=120
# Duración, en segundos, de la ventana del endpoint de tokens.
TOKEN_RATE_LIMIT_WINDOW_SECONDS=60

# Tamaño máximo del cuerpo multipart completo: 11 MiB para archivo de 10 MiB más cabeceras y campos.
CONTACT_MAX_REQUEST_BYTES=11534336

# Lista de orígenes HTTP(S) autorizados por CORS, separados por comas y sin rutas ni barra final.
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://galenn.asuscomm.com,https://paraisodeljamon.com,https://www.paraisodeljamon.com

# IP literales de proxies confiables autorizados para aportar X-Forwarded-For, separadas por comas.
# En Plesk con Nginx y FastAPI en el mismo servidor suele ser suficiente 127.0.0.1,::1.
TRUSTED_PROXY_IPS=127.0.0.1,::1

# Habilita Swagger, ReDoc y openapi.json. Valores admitidos: true | false. Mantén false en producción.
ENABLE_API_DOCS=false

# Entorno de ejecución usado por otros valores predeterminados. Valores admitidos: development | production.
APP_ENV=production
# Destino del log, independiente de APP_ENV. Valores admitidos: consola | archivo.
BACKEND_LOG_TARGET=archivo
# Nivel opcional. Valores admitidos: DEBUG | INFO | WARNING | ERROR | CRITICAL. Vacío usa DEBUG en development e INFO en production.
BACKEND_LOG_LEVEL=INFO
# Directorio absoluto y escribible fuera del document root público de Plesk.
BACKEND_LOG_DIR=/var/www/vhosts/paraisodeljamon.com/logs
# Tamaño máximo de backend.log antes de rotarlo (10 MiB).
BACKEND_LOG_MAX_BYTES=10485760
# Número de copias backend.log.1, backend.log.2, etc. que se conservan.
BACKEND_LOG_BACKUP_COUNT=10
# Registra también cada /health y /livez correcto. Valores admitidos: true | false. Los errores y cambios de estado siempre se registran.
BACKEND_LOG_HEALTHCHECKS=false

# Clave privada de reCAPTCHA v2. Nunca debe publicarse en el frontend.
RECAPTCHA_SECRET_KEY=cambiar_por_clave_secreta_de_recaptcha
# Hosts válidos que Google puede devolver tras verificar el CAPTCHA.
RECAPTCHA_ALLOWED_HOSTNAMES=localhost, 127.0.0.1,galenn.asuscomm.com,paraisodeljamon.com,www.paraisodeljamon.com
# Tiempo máximo, en segundos, para consultar el servicio de verificación de Google.
RECAPTCHA_TIMEOUT_SECONDS=5
