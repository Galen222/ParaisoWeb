{
  "name": "paraisoweb",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "node server.cjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build",
    "test": "npm run test:frontend && npm run test:backend",
    "test:frontend": "node --test tests/*.test.mjs",
    "test:backend": "cd .. && python -m backend.tests.run_all_tests"
  },
  "dependencies": {
    "@googlemaps/js-api-loader": "2.1.1",
    "animate.css": "^4.1.1",
    "axios": "^1.18.1",
    "bootstrap": "^5.3.8",
    "file-saver": "^2.0.5",
    "next": "^16.2.10",
    "next-seo": "7.2.0",
    "next-sitemap": "^4.2.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-ga4": "^3.0.1",
    "react-intl": "^10.1.16",
    "react-markdown": "^10.1.0",
    "react-share": "^5.3.0",
    "react-slick": "^0.31.0",
    "react-toastify": "^11.1.0",
    "slick-carousel": "^1.8.1",
    "validator": "^13.15.35"
  },
  "devDependencies": {
    "@types/file-saver": "^2.0.7",
    "@types/google.maps": "^3.65.2",
    "@types/node": "^22.20.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/validator": "^13.15.10",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.10",
    "eslint-plugin-react-hooks": "^7.1.1",
    "typedoc": "^0.28.20",
    "typescript": "^6.0.3"
  },
  "allowScripts": {
    "sharp@0.34.5": true,
    "unrs-resolver@1.12.2": true
  }
}
