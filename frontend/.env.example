# URL pública canónica del frontend, sin barra final.
NEXT_PUBLIC_SITE_URL=https://www.paraisodeljamon.com

# URL base del backend para obtener el token temporal.
NEXT_PUBLIC_API_URL=https://www.paraisodeljamon.com/api

# Endpoints completos usados por cada servicio frontend.
NEXT_PUBLIC_API_BLOG_URL=https://www.paraisodeljamon.com/api/blog
NEXT_PUBLIC_API_CHARCUTERIA_URL=https://www.paraisodeljamon.com/api/charcuteria
NEXT_PUBLIC_API_CONTACTO_URL=https://www.paraisodeljamon.com/api/contacto

# Google Maps JavaScript API.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=cambiar_por_clave_publica_de_google_maps

# Google Analytics 4. Déjalo vacío únicamente si no se utilizará Analytics.
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
