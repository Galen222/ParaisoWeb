# Origen público canónico del frontend, sin ruta ni barra final; se usa en SEO y URLs absolutas.
NEXT_PUBLIC_SITE_URL=https://www.paraisodeljamon.com

# URL pública base del backend desde la que el navegador obtiene el token temporal.
NEXT_PUBLIC_API_URL=https://www.paraisodeljamon.com/api
# Endpoint público completo del blog consumido por navegador y renderizado SSR.
NEXT_PUBLIC_API_BLOG_URL=https://www.paraisodeljamon.com/api/blog
# Endpoint público completo del catálogo de charcutería.
NEXT_PUBLIC_API_CHARCUTERIA_URL=https://www.paraisodeljamon.com/api/charcuteria
# Endpoint público completo que recibe el formulario de contacto.
NEXT_PUBLIC_API_CONTACTO_URL=https://www.paraisodeljamon.com/api/contacto

# Clave pública de Google Maps JavaScript API restringida por dominio en Google Cloud.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=cambiar_por_clave_publica_de_google_maps
# Identificador de medición de Google Analytics 4; déjalo vacío si Analytics no se utilizará.
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Endpoint interno que Next.js consulta desde el servidor para generar /sitemap.xml.
# Debe apuntar directamente al service local de FastAPI para cumplir la restricción loopback.
SITEMAP_API_URL=http://127.0.0.1:8000/api/sitemap/blog
